{
  "version": 2,
  "public": true,
  "installCommand": "git clone https://github.com/flutter/flutter.git -b stable --depth 1 && flutter/bin/flutter doctor",
  "buildCommand": "flutter/bin/flutter build web --release --dart-define=API_BASE_URL=https://your-backend.example.com",
  "outputDirectory": "build/web",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}